---
// Base layout — wraps every page
const pathname = Astro.url.pathname;
const navItems = [
  ["/books", "Books"],
  ["/blog", "Journal"],
  ["/world", "World"],
  ["/about", "About"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={Astro.props.description || "Aerthos — epic fantasy from Chris"} />

    <title>{Astro.props.title ? `${Astro.props.title} — Aerthos` : "Aerthos"}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="logo" aria-label="Aerthos home"><span class="logo-mark" aria-hidden="true"><span>A</span></span>Aerthos</a>
        <ul>
          {navItems.map(([href, label]) => (
            <li><a href={href} aria-current={pathname.startsWith(href) ? "page" : undefined}>{label}</a></li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-content">
        <p>&copy; {new Date().getFullYear()} Chris. All rights reserved.</p>
        <nav class="footer-nav">
          <a href="/newsletter">Newsletter</a>
          <a href="/about">About</a>
          <a href="/blog">Blog</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
