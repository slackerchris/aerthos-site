---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="About" description="About Chris, author and creator of the world of Aerthos.">
  <h1>About the Author</h1>
  <div class="about-content">
    <p class="lead">Chris Eckman is an Ohio-based fantasy writer, software developer, father, and lifelong builder of things.</p>
    <p>He is the author of the <a href="/books"><strong>Age of Reclamation</strong></a> series, set in the fractured world of Aerthos. His stories combine character-driven storytelling, deep history, dangerous magic, and a stubborn belief that ruin does not have to be the end.</p>
  </div>
  <blockquote>“Ruin is not the end. It is where the work begins.”</blockquote>
</PageLayout>

<style>
  .about-content { max-width: 42rem; }
  .about-content p { color: #cec9be; line-height: 1.85; }
  .lead { font-size: 1.2rem; }
  blockquote { margin: 3rem 0 0; padding: 2rem; border-left: 2px solid var(--gold); background: var(--tag-bg); color: var(--gold-bright); font-size: 1.35rem; font-style: italic; }
</style>
