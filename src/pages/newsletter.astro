---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="Newsletter" description="Sign up for Aerthos launch updates and lore.">
  <h1>Newsletter</h1>

  <p class="newsletter-intro">
    Get updates on the Age of Reclamation series, exclusive lore,
    behind-the-scenes content, and early previews — straight to your inbox.
  </p>

  <div class="newsletter-form-container">
    <p class="placeholder-note">
      Newsletter integration coming soon. For now, this will connect to
      a service like Buttondown, ConvertKit, or MailerLite.
    </p>

    <!-- Replace with your provider's embed code -->
    <form class="newsletter-form" action="#" method="post">
      <label for="email">Email address</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="you@example.com"
        required
        disabled
      />
      <button type="submit" class="btn btn-primary" disabled>Subscribe</button>
    </form>
  </div>
</PageLayout>

<style>
  .newsletter-intro {
    max-width: 36rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .newsletter-form-container {
    max-width: 28rem;
  }
  .placeholder-note {
    padding: 1rem;
    background: var(--tag-bg);
    border-radius: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .newsletter-form label {
    font-weight: 600;
  }
  .newsletter-form input {
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    font-size: 1rem;
    background: var(--bg);
    color: var(--text);
  }
</style>
