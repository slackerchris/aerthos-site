---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const latestPost = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
---

<BaseLayout title="Epic fantasy from a shattered world" description="Enter Aerthos, an epic fantasy world shattered by the Sundering. Begin the Age of Reclamation with Echo of the Sunstone.">
  <div class="home">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Book One · The Age of Reclamation</p>
        <h1>The world survived the Sundering.</h1>
        <p class="hook">It may not survive what wakes next.</p>
        <p class="description">Three thousand years after magic shattered the old world, a thief, a dwarven exile, and an elven weaver recover a divine relic capable of reshaping reality.</p>
        <div class="actions">
          <a href="/books/echo-of-the-sunstone/excerpt/" class="btn btn-primary">Read Chapter One</a>
          <a href="/books/echo-of-the-sunstone/" class="text-link">Meet the fellowship <span aria-hidden="true">→</span></a>
        </div>
      </div>

      <a class="hero-map" href="/world" aria-label="Explore the world of Aerthos">
        <img src="/images/aerthos-world-map.webp" alt="Illustrated map of Aerthos" width="2400" height="1800" />
        <span class="map-label"><small>The known world</small><strong>Explore Aerthos</strong></span>
      </a>
    </section>

    <nav class="discovery" aria-label="Discover Aerthos">
      <a href="/books">
        <span>01 · The series</span>
        <strong>Three books. One fractured world.</strong>
        <i aria-hidden="true">→</i>
      </a>
      <a href="/world">
        <span>02 · The atlas</span>
        <strong>Kingdoms, ruins, and the Weave.</strong>
        <i aria-hidden="true">→</i>
      </a>
      {latestPost && (
        <a href={`/blog/${latestPost.id.replace(/\.md$/, '')}/`}>
          <span>03 · From the journal</span>
          <strong>{latestPost.data.title}</strong>
          <i aria-hidden="true">→</i>
        </a>
      )}
    </nav>
  </div>
</BaseLayout>

<style>
  .home { max-width: 76rem; margin: auto; padding: clamp(2rem,5vw,4.5rem) 1.5rem 0; }
  .hero { min-height: 37rem; display: grid; grid-template-columns: 1.02fr .98fr; align-items: stretch; border: 1px solid var(--border); background: var(--bg-raised); }
  .hero-copy { padding: clamp(2.5rem,6vw,5.5rem); display: flex; flex-direction: column; justify-content: center; }
  .eyebrow { margin: 0 0 1.5rem; color: var(--gold); font-family: Arial,sans-serif; font-size: .65rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; }
  .hero h1 { max-width: 10ch; margin: 0; font-size: clamp(3rem,6vw,5.4rem); line-height: .94; }
  .hook { margin: 1.3rem 0 0; color: var(--gold-bright); font-size: clamp(1.25rem,2.2vw,1.65rem); font-style: italic; }
  .description { max-width: 34rem; margin: 1.5rem 0 2rem; color: var(--text-muted); font-size: 1rem; }
  .actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1.4rem; }
  .text-link { color: var(--text-muted); font-family: Arial,sans-serif; font-size: .67rem; letter-spacing: .09em; text-decoration: none; text-transform: uppercase; }
  .text-link span { margin-left: .5rem; color: var(--gold); }
  .text-link:hover { color: var(--gold-bright); }
  .hero-map { position: relative; min-height: 32rem; display: block; overflow: hidden; border-left: 1px solid var(--border); color: var(--text); text-decoration: none; }
  .hero-map::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top,rgba(20,15,9,.88),transparent 50%),linear-gradient(to right,rgba(16,15,12,.18),transparent 40%); box-shadow: inset 0 0 4rem rgba(20,13,6,.5); }
  .hero-map img { width: 100%; height: 100%; display: block; object-fit: cover; object-position: 57% center; transition: transform .7s ease; }
  .hero-map:hover img { transform: scale(1.025); }
  .map-label { position: absolute; z-index: 2; right: 2rem; bottom: 2rem; left: 2rem; display: flex; align-items: end; justify-content: space-between; gap: 1rem; }
  .map-label small { color: var(--gold-bright); font-family: Arial,sans-serif; font-size: .6rem; letter-spacing: .16em; text-transform: uppercase; }
  .map-label strong { font-size: 1.25rem; font-weight: 400; }
  .discovery { display: grid; grid-template-columns: repeat(3,1fr); border: 1px solid var(--border); border-top: 0; }
  .discovery a { position: relative; min-height: 9.5rem; padding: 1.5rem 3rem 1.5rem 1.5rem; display: flex; flex-direction: column; justify-content: end; color: var(--text); text-decoration: none; transition: background .2s; }
  .discovery a + a { border-left: 1px solid var(--border); }
  .discovery a:hover { background: var(--tag-bg); color: var(--text); }
  .discovery span { margin-bottom: .7rem; color: var(--gold); font-family: Arial,sans-serif; font-size: .58rem; letter-spacing: .15em; text-transform: uppercase; }
  .discovery strong { font-size: 1rem; font-weight: 400; line-height: 1.35; }
  .discovery i { position: absolute; right: 1.4rem; bottom: 1.4rem; color: var(--gold); font-style: normal; }
  @media (max-width:800px) { .home { padding: 1rem 1rem 0; } .hero { grid-template-columns: 1fr; } .hero-copy { padding: 3.5rem 1.5rem; } .hero-map { min-height: 22rem; border-top: 1px solid var(--border); border-left: 0; } .discovery { grid-template-columns: 1fr; } .discovery a { min-height: 8rem; } .discovery a + a { border-top: 1px solid var(--border); border-left: 0; } }
</style>
