---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const books = (await getCollection("books")).sort((a, b) => a.data.order - b.data.order);
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Epic fantasy from a shattered world" description="Enter Aerthos, an epic fantasy world shattered by the Sundering. Explore the Age of Reclamation books, lore, and character journals.">
  <section class="hero">
    <div class="hero-runes" aria-hidden="true">✦</div>
    <div class="hero-content">
      <p class="eyebrow">The Age of Reclamation</p>
      <h1>A world broken.<br /><em>Not yet lost.</em></h1>
      <p class="hero-description">The gods are gone. The old magic is waking. Across a land still scarred by the Sundering, unlikely heroes must decide what deserves to be reclaimed—and what should remain buried.</p>
      <div class="hero-actions">
        <a href="/books" class="btn btn-primary">Begin the journey <span aria-hidden="true">→</span></a>
        <a href="/world" class="btn btn-secondary">Explore the world</a>
      </div>
    </div>
    <p class="scroll-note">Enter Aerthos <span aria-hidden="true">↓</span></p>
  </section>

  <section class="series-section">
    <div class="section-heading">
      <div><p class="eyebrow">The Saga</p><h2>Three books. One fractured world.</h2></div>
      <a href="/books" class="text-link">View the complete series <span>→</span></a>
    </div>
    <div class="book-row">
      {books.map((book, index) => (
        <a class="book-card" href={`/books/${book.id.replace(/\.md$/, '')}/`}>
          <span class="book-number">0{index + 1}</span>
          <span class="book-status">{book.data.status}</span>
          <h3>{book.data.title}</h3>
          {book.data.subtitle && <p>{book.data.subtitle}</p>}
          <span class="card-arrow" aria-hidden="true">↗</span>
        </a>
      ))}
    </div>
  </section>

  <section class="world-callout">
    <div class="sigil" aria-hidden="true"><span>✦</span></div>
    <div>
      <p class="eyebrow">Beyond the page</p>
      <h2>Every ruin remembers.</h2>
      <p>Trace the history of the Sundering. Learn the laws of the Weave. Meet the gods whose absence still shapes every life in Aerthos.</p>
      <a href="/world" class="text-link">Enter the world atlas <span>→</span></a>
    </div>
  </section>

  <section class="journal-section">
    <div class="section-heading">
      <div><p class="eyebrow">From the journal</p><h2>Voices from Aerthos</h2></div>
      <a href="/blog" class="text-link">Read all entries <span>→</span></a>
    </div>
    <div class="post-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="post-card">
          <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</time>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <span>Read entry →</span>
        </a>
      ))}
    </div>
  </section>

  <section class="newsletter-cta">
    <p class="eyebrow">Stay near the fire</p>
    <h2>The story is still being written.</h2>
    <p>Get new chapters, world lore, and release news from the Age of Reclamation.</p>
    <a href="/newsletter" class="btn btn-primary">Join the newsletter</a>
  </section>
</BaseLayout>

<style>
  .eyebrow { margin: 0 0 1rem; color: var(--gold); font-family: Arial, sans-serif; font-size: .65rem; font-weight: 700; letter-spacing: .24em; text-transform: uppercase; }
  .hero { position: relative; min-height: calc(100vh - 4.6rem); padding: 7rem 1.5rem 5rem; display: grid; place-items: center; overflow: hidden; border-bottom: 1px solid var(--border); }
  .hero::before { content: ""; position: absolute; width: min(72vw, 54rem); aspect-ratio: 1; border: 1px solid rgba(214,182,109,.13); border-radius: 50%; box-shadow: 0 0 0 5rem rgba(214,182,109,.018), 0 0 0 10rem rgba(214,182,109,.012); }
  .hero::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 55%, var(--bg)), linear-gradient(110deg, rgba(155,73,52,.1), transparent 35%); pointer-events: none; }
  .hero-content { position: relative; z-index: 2; max-width: 56rem; text-align: center; }
  .hero h1 { margin-bottom: 1.5rem; font-size: clamp(3.3rem, 9vw, 7.3rem); line-height: .95; }
  .hero h1 em { color: var(--gold-bright); font-weight: 400; }
  .hero-description { max-width: 43rem; margin: 0 auto 2.2rem; color: #c6c2b8; font-size: clamp(1rem, 2vw, 1.15rem); }
  .hero-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: .8rem; }
  .hero-actions .btn-primary { gap: 1rem; }
  .hero-runes { position: absolute; z-index: 1; color: rgba(214,182,109,.14); font-size: min(34vw, 25rem); line-height: 1; }
  .scroll-note { position: absolute; z-index: 3; bottom: 1.5rem; margin: 0; color: var(--text-muted); font-family: Arial, sans-serif; font-size: .6rem; letter-spacing: .2em; text-transform: uppercase; }
  .scroll-note span { margin-left: .6rem; color: var(--gold); }
  .series-section, .journal-section { max-width: 76rem; margin: auto; padding: clamp(5rem, 10vw, 8rem) 1.5rem; }
  .section-heading { margin-bottom: 2.5rem; display: flex; align-items: end; justify-content: space-between; gap: 2rem; }
  .section-heading h2 { max-width: 32rem; margin: 0; }
  .text-link { flex-shrink: 0; color: var(--text-muted); font-family: Arial, sans-serif; font-size: .7rem; letter-spacing: .08em; text-decoration: none; text-transform: uppercase; }
  .text-link span { margin-left: .55rem; color: var(--gold); }
  .text-link:hover { color: var(--gold-bright); }
  .book-row { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .book-card { position: relative; min-height: 22rem; padding: 2rem; display: flex; flex-direction: column; color: var(--text); text-decoration: none; transition: background .25s; }
  .book-card + .book-card { border-left: 1px solid var(--border); }
  .book-card:hover { background: linear-gradient(145deg, rgba(214,182,109,.11), rgba(214,182,109,.02)); color: var(--text); }
  .book-number { color: var(--gold); font-size: .8rem; }
  .book-status { margin: auto 0 .75rem; color: var(--text-muted); font-family: Arial, sans-serif; font-size: .6rem; letter-spacing: .15em; text-transform: uppercase; }
  .book-card h3 { max-width: 12rem; margin: 0 0 .8rem; font-size: clamp(1.5rem, 3vw, 2.2rem); }
  .book-card p { max-width: 17rem; margin: 0; color: var(--text-muted); font-size: .85rem; font-style: italic; }
  .card-arrow { position: absolute; top: 1.6rem; right: 1.6rem; color: var(--text-muted); transition: color .2s, transform .2s; }
  .book-card:hover .card-arrow { color: var(--gold); transform: translate(3px,-3px); }
  .world-callout { position: relative; max-width: 76rem; margin: 0 auto; padding: clamp(4rem, 8vw, 7rem); display: grid; grid-template-columns: .8fr 1.2fr; align-items: center; gap: clamp(3rem, 8vw, 8rem); border: 1px solid var(--border); background: linear-gradient(120deg, rgba(155,73,52,.09), rgba(214,182,109,.035)); overflow: hidden; }
  .world-callout h2 { margin: 0 0 1rem; }
  .world-callout > div:last-child > p:not(.eyebrow) { max-width: 35rem; color: var(--text-muted); }
  .sigil { width: min(100%, 18rem); aspect-ratio: 1; margin: auto; display: grid; place-items: center; border: 1px solid var(--border-strong); border-radius: 50%; color: var(--gold); font-size: 4rem; box-shadow: inset 0 0 0 2rem rgba(214,182,109,.025), 0 0 5rem rgba(155,73,52,.12); }
  .sigil span { width: 58%; aspect-ratio: 1; display: grid; place-items: center; border: 1px solid var(--border); transform: rotate(45deg); }
  .post-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .post-card { min-height: 19rem; padding: 2rem; display: flex; flex-direction: column; background: var(--bg-raised); color: var(--text); text-decoration: none; transition: background .2s; }
  .post-card:hover { background: var(--surface-soft); color: var(--text); }
  .post-card time { color: var(--gold); font-family: Arial, sans-serif; font-size: .62rem; letter-spacing: .12em; text-transform: uppercase; }
  .post-card h3 { margin: 2.5rem 0 .8rem; font-size: 1.4rem; }
  .post-card p { color: var(--text-muted); font-size: .85rem; }
  .post-card > span { margin-top: auto; color: var(--gold); font-family: Arial, sans-serif; font-size: .65rem; letter-spacing: .1em; text-transform: uppercase; }
  .newsletter-cta { max-width: 76rem; margin: 0 auto 2rem; padding: clamp(5rem, 10vw, 8rem) 1.5rem; text-align: center; border-top: 1px solid var(--border); }
  .newsletter-cta h2 { margin: 0 0 1rem; }
  .newsletter-cta > p:not(.eyebrow) { max-width: 34rem; margin: 0 auto 2rem; color: var(--text-muted); }
  @media (max-width: 760px) { .book-row, .post-grid { grid-template-columns: 1fr; } .book-card { min-height: 17rem; } .book-card + .book-card { border-left: 0; border-top: 1px solid var(--border); } .world-callout { margin-inline: 1rem; padding: 3rem 1.5rem; grid-template-columns: 1fr; } .sigil { width: 11rem; } .section-heading { align-items: start; flex-direction: column; } }
</style>
