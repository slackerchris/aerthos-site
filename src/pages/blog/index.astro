---
import PageLayout from "../../layouts/PageLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout title="Blog" description="Writing updates and lore from the world of Aerthos.">
  <h1>Blog</h1>

  {posts.length === 0 ? (
    <p>No posts yet. Check back soon for writing updates and lore deep-dives.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <a href={`/blog/${post.id}/`}>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  )}
</PageLayout>

<style>
  .post-list {
    list-style: none;
    padding: 0;
  }
  .post-item {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .post-item a {
    text-decoration: none;
    color: inherit;
  }
  .post-item h2 {
    margin-bottom: 0.25rem;
  }
  .post-item p {
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .post-item time {
    font-size: 0.875rem;
    color: var(--text-muted);
  }
</style>
